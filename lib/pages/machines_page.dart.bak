                        itemCount: bacs.length,
                        itemBuilder: (context, index) {
                          String typeName = bacs.keys.elementAt(index);
                          Map<String, dynamic> bacData = bacs[typeName];
                          double fillLevel = bacData['fillLevel'] ?? 0.0;
                          String lastEmptied =
                              bacData['lastEmptied'] ?? "Inconnu";

                          Color progressColor = fillLevel > 0.85
                              ? Colors.red
                              : (fillLevel > 0.6
                                    ? Colors.orange
